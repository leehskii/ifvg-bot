TRADOVATE_USERNAME=your_username
TRADOVATE_PASSWORD=your_password
TRADOVATE_APP_ID=your_app_id
TRADOVATE_APP_VERSION=1.0
TRADOVATE_DEVICE_ID=your_device_id
TRADOVATE_CID=your_cid
TRADOVATE_SECRET=your_secret

# "demo" to paper trade, "live" for real money — always test on demo first
TRADOVATE_ENV=demo

WEBHOOK_SECRET=your_webhook_secret
WEBHOOK_PORT=8080

# MNQ contract — update expiry each quarter: MNQM5(Jun), MNQU5(Sep), MNQZ5(Dec), MNQH6(Mar)
INSTRUMENT=MNQM5
MNQ_PER_POINT=2.0

# Risk caps
RISK_PER_TRADE=100.0
MAX_RISK_USD=130.0

# Telegram notifications (optional — delete or leave blank to disable)
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
